# ================================================================
# Layout Definition File for FRS.layout
# ================================================================

# ⚙️ BASIC INFO
INPUT_SOURCE_NAME="French Symbols (Canada) "
SHORT_NAME="FRS"
LANGUAGE_CODE="fr"
COUNTRY_CODE="CA"
FLAG="🇨🇦"

   // First row - Numbers and symbols
    // Standard:    ² & é " apostrophe ( - è _ ç à ) =
    // Shift:       ~ 1 2 3 4 5 6 7 8 9 0 ° +
    // AltGr:       ³ ∑ ² # { [ | grave \ # @ ] }
    // AltGr+Shift: ⁴ ∥ ½ ⅓ ¼ ★ ✴ ☽ ∞ ⊙ φ ○ ≠

    key <TLDE> { [ twosuperior   , asciitilde    , threesuperior , foursuperior ] };// ² ~ ³ ⁴
    key <AE01> { [ ampersand     , 1             , U2211         , U2225 ] };// & 1 ∑ ∥
    key <AE02> { [ eacute        , 2             , twosuperior   , onehalf ] };// é 2 ² ½
    key <AE03> { [ quotedbl      , 3             , numbersign    , onethird ] };// " 3 # ⅓
    key <AE04> { [ apostrophe    , 4             , braceleft     , onequarter ] };// apostrophe 4 { ¼
    key <AE05> { [ parenleft     , 5             , bracketleft   , U2605 ] };// ( 5 [ ★
    key <AE06> { [ minus         , 6             , bar           , U2734 ] };// - 6 | ✴
    key <AE07> { [ egrave        , 7             , grave         , U263D ] };// è 7 grave ☽
    key <AE08> { [ underscore    , 8             , backslash     , infinity ] };// _ 8 \ ∞
    key <AE09> { [ ccedilla      , 9             , numbersign    , U2299 ] };// ç 9 # ⊙
    key <AE10> { [ agrave        , 0             , at            , Greek_phi ] };// à 0 @ φ
    key <AE11> { [ parenright    , degree        , bracketright  , circle ] };// ) ° ] ○
    key <AE12> { [ equal         , plus          , braceright    , notequal ] };// = + } ≠

    // Second row - QWERTY (with Enter)
    // Standard:    a z e r t y u i o p ﹒ $
    // Shift:       A Z E R T Y   I O P ˇ €
    // AltGr:       æ ž ∃ ⏺ △ ¥ ∪ í oslash π « £
    // AltGr+Shift: Æ Ⓩ ∈ ® ™ Ɏ ∩ ï Oslash Π » ₩

    key <AD01> { [ a             , A             , ae            , AE ] };  // a A æ Æ
    key <AD02> { [ z             , Z             , zcaron        , U24CF ] };// z Z ž Ⓩ
    key <AD03> { [ e             , E             , U2203         , elementof ] };// e E ∃ ∈
    key <AD04> { [ r             , R             , U23FA         , registered ] };// r R ⏺ ®
    key <AD05> { [ t             , T             , U25B3         , trademark ] };// t T △ ™
    key <AD06> { [ y             , Y             , yen           , U024E ] };// y Y ¥ Ɏ
    key <AD07> { [ u             , U             , union         , intersection ] };// u   ∪ ∩
    key <AD08> { [ i             , I             , iacute        , idiaeresis ] };// i I í ï
    key <AD09> { [ o             , O             , oslash        , Oslash ] };// o O oslash Oslash
    key <AD10> { [ p             , P             , Greek_pi      , Greek_PI ] };// p P π Π
    key <AD11> { [ dead_circumflex, caron         , guillemotleft , guillemotright ] };// ﹒ ˇ « »
    key <AD12> { [ dollar        , EuroSign      , sterling      , WonSign ] };// $ € £ ₩

    // Third row - ASDF (with CapsLock)
    // Standard:    q s d f g h j k l m ù *
    // Shift:       Q S D F G H J K L M % ×
    // AltGr:       ω Σ partialderivative ƒ < > ∫ ₭ ℓ µ p ÷
    // AltGr+Shift: Ω § ETH Ⓕ ≤ ≥ ∮ ⌨ ₤ ⁻ ≈ ❄

    key <AC01> { [ q             , Q             , Greek_omega   , Greek_OMEGA ] };// q Q ω Ω
    key <AC02> { [ s             , S             , Greek_SIGMA   , section ] };// s S Σ §
    key <AC03> { [ d             , D             , partialderivative, ETH ] };// d D partialderivative ETH
    key <AC04> { [ f             , F             , function      , U24BB ] };// f F ƒ Ⓕ
    key <AC05> { [ g             , G             , less          , lessthanequal ] };// g G < ≤
    key <AC06> { [ h             , H             , greater       , greaterthanequal ] };// h H > ≥
    key <AC07> { [ j             , J             , integral      , U222E ] };// j J ∫ ∮
    key <AC08> { [ k             , K             , U20AD         , U2328 ] };// k K ₭ ⌨
    key <AC09> { [ l             , L             , U2113         , LiraSign ] };// l L ℓ ₤
    key <AC10> { [ m             , M             , mu            , U207B ] };// m M µ ⁻
    key <AC11> { [ ugrave        , percent       , p             , U2248 ] };// ù % p ≈
    key <BKSL> { [ asterisk      , multiply      , division      , U2744 ] };// * × ÷ ❄

    // Fourth row - ZXCV (with Shift)
    // Standard:    < w x c v b n , ; : !
    // Shift:       > W X C V B N ? . / ¡
    // AltGr:       ≤ ω × ¢ radical β ñ ¿ b \ ⟨
    // AltGr+Shift: ≥ ₩ ✗ © ✓ ₿ Ñ ‽ … ÷ ⟩

    key <LSGT> { [ less          , greater       , lessthanequal , greaterthanequal ] };// < > ≤ ≥
    key <AB01> { [ w             , W             , Greek_omega   , WonSign ] };// w W ω ₩
    key <AB02> { [ x             , X             , multiply      , ballotcross ] };// x X × ✗
    key <AB03> { [ c             , C             , cent          , copyright ] };// c C ¢ ©
    key <AB04> { [ v             , V             , radical       , checkmark ] };// v V radical ✓
    key <AB05> { [ b             , B             , Greek_beta    , U20BF ] };// b B β ₿
    key <AB06> { [ n             , N             , ntilde        , Ntilde ] };// n N ñ Ñ
    key <AB07> { [ comma         , question      , questiondown  , U203D ] };// , ? ¿ ‽
    key <AB08> { [ semicolon     , period        , b             , ellipsis ] };// ; . b …
    key <AB09> { [ colon         , slash         , backslash     , division ] };// : / \ ÷
    key <AB10> { [ exclam        , exclamdown    , U27E8         , U27E9 ] };// ! ¡ ⟨ ⟩

    // Fifth row - Bottom (Ctrl, Win, Alt, Space, AltGr, Menu)
    // Standard:    
    // Shift:       
    // AltGr:       
    // AltGr+Shift: 

    key <SPCE> { [ space         , space         , nobreakspace  , U202F ] };//        

    // Arrow keys
    // Standard:    ｔ ｑ ｓ
    // Shift:       ｔ ｑ ｓ
    // AltGr:       ↑ ↓ ← →
    // AltGr+Shift: ⇧ ⇩ ⇦ ⇨

    key <UP> { [ Up            , Up            , uparrow       , U21E7 ] }; //     ↑ ⇧
    key <DOWN> { [ Down          , Down          , downarrow     , U21E9 ] };// ｔ ｔ ↓ ⇩
    key <LEFT> { [ Left          , Left          , leftarrow     , U21E6 ] };// ｑ ｑ ← ⇦
    key <RGHT> { [ Right         , Right         , rightarrow    , U21E8 ] };// ｓ ｓ → ⇨

    // Numpad
    // Standard:    7 8 9   4 5 6 1 2 3   0 .
    // Shift:       Ⅶ Ⅷ Ⅸ   Ⅳ Ⅴ Ⅵ Ⅰ Ⅱ Ⅲ   Ⅹ #
    // AltGr:       ⅶ ⅷ ⅸ   ⅳ ⅴ ⅵ ⅰ ⅱ ⅲ   ⅹ Ⅽ
    // AltGr+Shift: ❼ ❽ ❾   ❹ ❺ ❻ ❶ ❷ ❸   ❿ Ⅾ
    key <KPDV> { [ U002F         , U00F7         , U2298         , U2705 ] };// slash division ⊘ ✅
    key <KPMU> { [ U002A         , U00D7         , U2297         , U274C ] };// asterisk multiply ⊗ ❌
    key <KPSU> { [ U002D         , U007E         , U25AC         , U2796 ] };// minus asciitilde ▬ ➖
    key <KP7> { [ 7             , U2166         , U2176         , U277C ] };// 7 Ⅶ ⅶ ❼
    key <KP8> { [ 8             , U2167         , U2177         , U277D ] };// 8 Ⅷ ⅷ ❽
    key <KP9> { [ 9             , U2168         , U2178         , U277E ] };// 9 Ⅸ ⅸ ❾
    key <KP4> { [ 4             , U2163         , U2173         , U2779 ] };// 4 Ⅳ ⅳ ❹
    key <KP5> { [ 5             , U2164         , U2174         , U277A ] };// 5 Ⅴ ⅴ ❺
    key <KP6> { [ 6             , U2165         , U2175         , U277B ] };// 6 Ⅵ ⅵ ❻
    key <KP1> { [ 1             , U2160         , U2170         , U2776 ] };// 1 Ⅰ ⅰ ❶
    key <KP2> { [ 2             , U2161         , U2171         , U2777 ] };// 2 Ⅱ ⅱ ❷
    key <KP3> { [ 3             , U2162         , U2172         , U2778 ] };// 3 Ⅲ ⅲ ❸
    key <KP0> { [ 0             , U2169         , U2179         , U277F ] };// 0 Ⅹ ⅹ ❿
    key <KPDL> { [ period        , U2753         , U2757         , U2B55 ] };// . ❓ ❗ ⭕
