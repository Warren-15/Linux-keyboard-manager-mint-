# ================================================================
# Layout Definition File for ARP.layout
# ================================================================

# ⚙️ BASIC INFO
INPUT_SOURCE_NAME="Arabic Phonkeys (Tunisia)"
SHORT_NAME="ARP"
LANGUAGE_CODE="ar"
COUNTRY_CODE="TN"
FLAG="🇹🇳"

    // First row - Numbers and symbols
    // Standard:    ² & é " apostrophe ( - è _ ç à ) =
    // Shift:       ~ 1 2 3 4 5 6 7 8 9 0 ° +
    // AltGr:       ³ ∑ ² # { [ | grave \ # @ ] }
    // AltGr+Shift: ⁴ ∥ ½ ⅓ ¼ ★ ✴ ☽ ∞ ⊙ φ ○ ≠

    key <TLDE> { [ twosuperior   , asciitilde    , threesuperior , foursuperior ] };// ² ~ ³ ⁴
    key <AE01> { [ ampersand     , 1             , U2211         , U2225 ] };// & 1 ∑ ∥
    key <AE02> { [ eacute        , 2             , twosuperior   , onehalf ] };// é 2 ² ½
    key <AE03> { [ quotedbl      , 3             , numbersign    , onethird ] };// " 3 # ⅓
    key <AE04> { [ apostrophe    , 4             , braceleft     , onequarter ] };// apostrophe 4 { ¼
    key <AE05> { [ parenleft     , 5             , bracketleft   , U2605 ] };// ( 5 [ ★
    key <AE06> { [ minus         , 6             , bar           , U2734 ] };// - 6 | ✴
    key <AE07> { [ egrave        , 7             , grave         , U263D ] };// è 7 grave ☽
    key <AE08> { [ underscore    , 8             , backslash     , infinity ] };// _ 8 \ ∞
    key <AE09> { [ ccedilla      , 9             , numbersign    , U2299 ] };// ç 9 # ⊙
    key <AE10> { [ agrave        , 0             , at            , Greek_phi ] };// à 0 @ φ
    key <AE11> { [ parenright    , degree        , bracketright  , circle ] };// ) ° ] ○
    key <AE12> { [ equal         , plus          , braceright    , notequal ] };// = + } ≠

    // Second row - QWERTY (with Enter)
    // Standard:    ا ز ى ر ت ي ع إ ة ء ﹒ $
    // Shift:       أ ظ آ غ ط ئ ُ ِ ْ پ ˇ €
    // AltGr:       æ ž ∃ ⏺ △ ¥ ∪ í oslash π « £
    // AltGr+Shift: Æ Ⓩ ∈ ® ™ Ɏ ∩ ï Oslash Π » ₩

    key <AD01> { [ Arabic_alef   , Arabic_hamzaonalef, ae            , AE ] };// ا أ æ Æ
    key <AD02> { [ Arabic_zain   , Arabic_zah    , zcaron        , U24CF ] };// ز ظ ž Ⓩ
    key <AD03> { [ Arabic_alefmaksura, Arabic_maddaonalef, U2203         , elementof ] };// ى آ ∃ ∈
    key <AD04> { [ Arabic_ra     , Arabic_ghain  , U23FA         , registered ] };// ر غ ⏺ ®
    key <AD05> { [ Arabic_teh    , Arabic_tah    , U25B3         , trademark ] };// ت ط △ ™
    key <AD06> { [ Arabic_yeh    , Arabic_hamzaonyeh, yen           , U024E ] };// ي ئ ¥ Ɏ
    key <AD07> { [ Arabic_ain    , Arabic_damma  , union         , intersection ] };// ع ُ ∪ ∩
    key <AD08> { [ Arabic_hamzaunderalef, Arabic_kasra  , iacute        , idiaeresis ] };// إ ِ í ï
    key <AD09> { [ Arabic_tehmarbuta, Arabic_sukun  , oslash        , Oslash ] };// ة ْ oslash Oslash
    key <AD10> { [ Arabic_hamza  , Arabic_peh    , Greek_pi      , Greek_PI ] };// ء پ π Π
    key <AD11> { [ dead_circumflex, caron         , guillemotleft , guillemotright ] };// ﹒ ˇ « »
    key <AD12> { [ dollar        , EuroSign      , sterling      , WonSign ] };// $ € £ ₩

    // Third row - ASDF (with CapsLock)
    // Standard:    ق س د ف ج ه خ ك ل م ù *
    // Shift:       ً ص ض َ غ ح ٌ ٍ ـ م % ×
    // AltGr:       ڨ Σ partialderivative ƒ < > ∫ ₭ ℓ µ p ÷
    // AltGr+Shift: Ω § ETH Ⓕ ≤ ≥ ∮ ⌨ ₤ ⁻ ≈ ❄

    key <AC01> { [ Arabic_qaf    , Arabic_fathatan, Serbian_je    , U2126 ] };// ق ً ڨ Ω
    key <AC02> { [ Arabic_seen   , Arabic_sad    , Greek_SIGMA   , section ] };// س ص Σ §
    key <AC03> { [ Arabic_dal    , Arabic_dad    , partialderivative, ETH ] };// د ض partialderivative ETH
    key <AC04> { [ Arabic_feh    , Arabic_fatha  , function      , U24BB ] };// ف َ ƒ Ⓕ
    key <AC05> { [ Arabic_jeem   , Arabic_ghain  , less          , lessthanequal ] };// ج غ < ≤
    key <AC06> { [ Arabic_ha     , Arabic_hah    , greater       , greaterthanequal ] };// ه ح > ≥
    key <AC07> { [ Arabic_khah   , Arabic_dammatan, integral      , U222E ] };// خ ٌ ∫ ∮
    key <AC08> { [ Arabic_kaf    , Arabic_kasratan, U20AD         , U2328 ] };// ك ٍ ₭ ⌨
    key <AC09> { [ Arabic_lam    , Arabic_tatweel, U2113         , LiraSign ] };// ل ـ ℓ ₤
    key <AC10> { [ Arabic_meem   , Arabic_meem   , mu            , U207B ] };// م م µ ⁻
    key <AC11> { [ ugrave        , percent       , p             , U2248 ] };// ù % p ≈
    key <BKSL> { [ asterisk      , multiply      , division      , U2744 ] };// * × ÷ ❄

    // Fourth row - ZXCV (with Shift)
    // Standard:    < و ش ث ذ ب ن ، ; : !
    // Shift:       > ؤ ّ ث پ ب N ؟ . / ¡
    // AltGr:       ≤ ω × ¢ radical β ñ ¿ b \ ⟨
    // AltGr+Shift: ≥ ₩ ✗ © ✓ ₿ Ñ , … ÷ ⟩

    key <LSGT> { [ less          , greater       , lessthanequal , greaterthanequal ] };// < > ≤ ≥
    key <AB01> { [ Arabic_waw    , Arabic_hamzaonwaw, Greek_omega   , WonSign ] };// و ؤ ω ₩
    key <AB02> { [ Arabic_sheen  , Arabic_shadda , multiply      , ballotcross ] };// ش ّ × ✗
    key <AB03> { [ Arabic_theh   , Arabic_theh   , cent          , copyright ] };// ث ث ¢ ©
    key <AB04> { [ Arabic_thal   , Arabic_peh    , radical       , checkmark ] };// ذ پ radical ✓
    key <AB05> { [ Arabic_beh    , Arabic_beh    , Greek_beta    , U20BF ] };// ب ب β ₿
    key <AB06> { [ Arabic_noon   , N             , ntilde        , Ntilde ] };// ن N ñ Ñ
    key <AB07> { [ Arabic_comma  , Arabic_question_mark, questiondown  , comma ] };// ، ؟ ¿ ,
    key <AB08> { [ semicolon     , period        , b             , ellipsis ] };// ; . b …
    key <AB09> { [ colon         , slash         , backslash     , division ] };// : / \ ÷
    key <AB10> { [ exclam        , exclamdown    , U27E8         , U27E9 ] };// ! ¡ ⟨ ⟩

    // Fifth row - Bottom (Ctrl, Win, Alt, Space, AltGr, Menu)
    // Standard:    
    // Shift:       
    // AltGr:       
    // AltGr+Shift: 

    key <SPCE> { [               , U2015         , U005F         , U25AC ] };//  Greek_horizbar underscore ▬

    // Arrow keys
    // Standard:    ｔ ｑ ｓ
    // Shift:       ｔ ｑ ｓ
    // AltGr:       ↑ ↓ ← →
    // AltGr+Shift: ⇧ ⇩ ⇦ ⇨

    key <UP> { [ Up            , Up            , uparrow       , U21E7 ] }; //     ↑ ⇧
    key <DOWN> { [ Down          , Down          , downarrow     , U21E9 ] };// ｔ ｔ ↓ ⇩
    key <LEFT> { [ Left          , Left          , leftarrow     , U21E6 ] };// ｑ ｑ ← ⇦
    key <RGHT> { [ Right         , Right         , rightarrow    , U21E8 ] };// ｓ ｓ → ⇨

    // Numpad
    // Standard:    slash asterisk minus 7 8 9 plus 4 5 6 1 2 3   0 .
    // Shift:       division multiply asciitilde Ⅶ Ⅷ Ⅸ ⊕ Ⅳ Ⅴ Ⅵ Ⅰ Ⅱ Ⅲ   Ⅹ ❓
    // AltGr:       ⊘ ⊗ ▬ ٧ ٨ ۹ plusminus ٤ ٥ ٦ ١ ٢ ٣   ٠ ❗
    // AltGr+Shift: ✅ ❌ ➖ ❼ ❽ ❾ ➕ ❹ ❺ ❻ ❶ ❷ ❸   ❿ ⭕


    key <KP7> { [ 7             , U2166         , Arabic_7      , U277C ] };// 7 Ⅶ ٧ ❼
    key <KP8> { [ 8             , U2167         , Arabic_8      , U277D ] };// 8 Ⅷ ٨ ❽
    key <KP9> { [ 9             , U2168         , Farsi_9       , U277E ] };// 9 Ⅸ ۹ ❾
    key <KP4> { [ 4             , U2163         , Arabic_4      , U2779 ] };// 4 Ⅳ ٤ ❹
    key <KP5> { [ 5             , U2164         , Arabic_5      , U277A ] };// 5 Ⅴ ٥ ❺
    key <KP6> { [ 6             , U2165         , Arabic_6      , U277B ] };// 6 Ⅵ ٦ ❻
    key <KP1> { [ 1             , U2160         , Arabic_1      , U2776 ] };// 1 Ⅰ ١ ❶
    key <KP2> { [ 2             , U2161         , Arabic_2      , U2777 ] };// 2 Ⅱ ٢ ❷
    key <KP3> { [ 3             , U2162         , Arabic_3      , U2778 ] };// 3 Ⅲ ٣ ❸
    key <KP0> { [ 0             , U2169         , Arabic_0      , U277F ] };// 0 Ⅹ ٠ ❿
    key <KPDL> { [ period        , U2753         , U2757         , U2B55 ] };// . ❓ ❗ ⭕
