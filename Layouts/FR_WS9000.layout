# ================================================================
# Layout Definition File
# ================================================================


# ⚙️ BASIC INFO
INPUT_SOURCE_NAME="French WS9000 (AZERTY)"
SHORT_NAME="FWS"
LANGUAGE_CODE="fr"
COUNTRY_CODE="FR"
FLAG="🇫🇷"

    // Standard:    ² & é " '"'"' ( - è _ ç à ) =
    // Shift:       ~ 1 2 3 4 5 6 7 8 9 0 ° +
    // AltGr:       ¬ | ~ # { [ | ` \ ^ @ ] }
    // AltGr+Shift: ¬ ¡ ⅛ £ $ « ⅝ ⅞ ™ ± ° » ˛

    // First row - Numbers and symbols
    key <TLDE> { [          twosuperior,     asciitilde,  notsign,      notsign      ] }; // ² ~ ¬ ¬
    key <AE01> { [          ampersand,       1,          bar,          section       ] }; // & 1 | §
    key <AE02> { [          eacute,          2,          asciitilde,   oneeighth     ] }; // é 2 ~ ⅛
    key <AE03> { [          quotedbl,        3,          numbersign,   sterling      ] }; // " 3 # £
    key <AE04> { [          apostrophe,      4,          braceleft,    dollar        ] }; // '"'"' 4 { $
    key <AE05> { [          parenleft,       5,          bracketleft, guillemotleft  ] }; // ( 5 [ «
    key <AE06> { [          minus,           6,          bar,          fiveeighths   ] }; // - 6 | ⅝
    key <AE07> { [          egrave,          7,          grave,        seveneighths  ] }; // è 7 ` ⅞
    key <AE08> { [          underscore,      8,          backslash,    trademark     ] }; // _ 8 \ ™
    key <AE09> { [          ccedilla,          9,          asciicircum,  plusminus     ] }; // ç 9 ^ ±
    key <AE10> { [          agrave,          0,          at,           degree        ] }; // à 0 @ °
    key <AE11> { [          parenright,      degree,     braceright,  guillemotright ] }; // ) ° } »
    key <AE12> { [          equal,           plus,       braceright,   dead_ogonek   ] }; // = + } ˛

    // Second row - Letters
    // Standard: a z e r t y u i o p ^ $
    // Shift:    A Z E R T Y U I O P " £
    // AltGr:    æ « € ¶ ŧ ← ↓ → ø þ " ¤
    // AltGr+Shift: Æ ł ¢ ® Ŧ ¥ ↑ ı Ø Þ ° ¯
    key <AD01> { [          a,               A,          ae,           AE            ] }; // a A æ Æ
    key <AD02> { [          z,               Z,          guillemotleft, lstroke      ] }; // z Z « ł
    key <AD03> { [          e,               E,          euro,         cent          ] }; // e E € ¢
    key <AD04> { [          r,               R,          paragraph,    registered    ] }; // r R ¶ ®
    key <AD05> { [          t,               T,          Tstroke,      trademark     ] }; // t T ŧ ™
    key <AD06> { [          y,               Y,          leftarrow,    yen           ] }; // y Y ← ¥
    key <AD07> { [          u,               U,          downarrow,    uparrow       ] }; // u U ↓ ↑
    key <AD08> { [          i,               I,          rightarrow,   idotless      ] }; // i I → ı
    key <AD09> { [          o,               O,          oslash,       Oslash        ] }; // o O ø Ø
    key <AD10> { [          p,               P,          thorn,        THORN         ] }; // p P þ Þ
    key <AD11> { [          dead_circumflex, quotedbl,   quotedbl,     degree        ] }; // ^ " " °
    key <AD12> { [          dollar,          sterling,   currency,     macron        ] }; // $ £ ¤ ¯

    // Third row - Letters
    // Standard: q s d f g h j k l m ù *
    // Shift:    Q S D F G H J K L M % µ
    // AltGr:    @ ß ð đ ŋ ħ ̉ĸ ł µ ^ `
    // AltGr+Shift: Ω § Ð ª Ŋ Ħ ̛ & Ł º ˇ ˘
    key <AC01> { [          q,               Q,          at,           U2126         ] }; // q Q @ Ω
    key <AC02> { [          s,               S,          ssharp,       U2714         ] }; // s S ß ✅
    key <AC03> { [          d,               D,          eth,          ETH           ] }; // d D ð Ð
    key <AC04> { [          f,               F,          dstroke,      U2716         ] }; // f F đ ❖
    key <AC05> { [          g,               G,          eng,          Eng           ] }; // g G ŋ Ŋ
    key <AC06> { [          h,               H,          hstroke,      Hstroke       ] }; // h H ħ Ħ
    key <AC07> { [          j,               J,          dead_acute,   dead_breve    ] }; // j J ´ ̛
    key <AC08> { [          k,               K,          kra,          U2328         ] }; // k K ĸ ⌨
    key <AC09> { [          l,               L,          lstroke,      Lstroke       ] }; // l L ł Ł
    key <AC10> { [          m,               M,          mu,           masculine     ] }; // m M μ º
    key <AC11> { [          ugrave,          percent,    asciicircum,  dead_caron    ] }; // ù % ^ ˇ
    key <BKSL> { [          asterisk,        mu,         grave,        dead_breve    ] }; // * μ ` ˘

    // Fourth row - Letters
    // Standard:    w x c v b n , ; : !
    // Shift:       W X C V B N ? . / §
    // AltGr:       < > ¢ " " n '"'"' ; · ̣
    // AltGr+Shift: ≤ ≥ © '"'"' '"'"' Ñ ˝ × ÷ ˙
    key <AB01> { [          w,               W,          less,         lessthanequal     ] }; // w W < ≤
    key <AB02> { [          x,               X,          greater,      greaterthanequal  ] }; // x X > ≥
    key <AB03> { [          c,               C,          cent,         copyright     ] }; // c C ¢ ©
    key <AB04> { [          v,               V,          leftdoublequotemark, leftsinglequotemark  ] }; // v V " '"'"'
    key <AB05> { [          b,               B,          U20BF,           U03C0 ] }; // b B ₿ π
    key <AB06> { [          n,               N,          ntilde,          U00D1 ] }; // n N ñ Ñ
    key <AB07> { [          comma,           question,   questiondown,        dead_doubleacute ] }; // , ? ¿ ˝
    key <AB08> { [          semicolon,       period,         multiply,        ellipsis      ] }; // ; . × ellipsis
    key <AB09> { [          colon,           slash,      period,       division      ] }; // : / . ÷
    key <AB10> { [          exclam,          exclamdown,    dead_abovedot, dead_abovedot ] }; // ! ¡ · ˙

    // Bottom row
    key <LSGT> { [          less,            greater,     lessthanequal,   greaterthanequal  ] }; // < > < >

    // Space key
    key <SPCE> { [          space,           space,      nobreakspace, narrownobreakspace ] };

    // Modifier keys
    key <LFSH> { [          Shift_L         ] };
    key <RTSH> { [          Shift_R         ] };
    key <LCTL> { [          Control_L       ] };
    key <RCTL> { [          Control_R       ] };
    key <CAPS> { [          Caps_Lock       ] };
    key <LALT> { [          Alt_L           ] };
    key <RALT> { [          Mode_switch     ] }; // This is AltGr
 
