# ================================================================
# Layout Definition File for ARP_Emoji.layout
# ================================================================

# ⚙️ BASIC INFO
INPUT_SOURCE_NAME="Arabic PhonEmojis (Tunisia)"
SHORT_NAME="A😃"
LANGUAGE_CODE="ar"
COUNTRY_CODE="tn"
FLAG="🇹🇳"

     // First row - Numbers and symbols
    // Standard:    ² & é " apostrophe ( - è _ ç à ) =
    // Shift:       ~ 1 2 3 4 5 6 7 8 9 0 ° +
    // AltGr:       ³ ∑ ² # { [ | grave \ # @ ] }
    // AltGr+Shift: ⁴ ∥ ½ ⅓ ¼ ★ ✴ ☽ ∞ ⊙ φ ○ ≠

    key <TLDE> { [ twosuperior   , asciitilde    , threesuperior , foursuperior ] };// ² ~ ³ ⁴
    key <AE01> { [ ampersand     , 1             , U2211         , U2225 ] };// & 1 ∑ ∥
    key <AE02> { [ eacute        , 2             , twosuperior   , onehalf ] };// é 2 ² ½
    key <AE03> { [ quotedbl      , 3             , numbersign    , onethird ] };// " 3 # ⅓
    key <AE04> { [ apostrophe    , 4             , braceleft     , onequarter ] };// apostrophe 4 { ¼
    key <AE05> { [ parenleft     , 5             , bracketleft   , U2605 ] };// ( 5 [ ★
    key <AE06> { [ minus         , 6             , bar           , U2734 ] };// - 6 | ✴
    key <AE07> { [ egrave        , 7             , grave         , U263D ] };// è 7 grave ☽
    key <AE08> { [ underscore    , 8             , backslash     , infinity ] };// _ 8 \ ∞
    key <AE09> { [ ccedilla      , 9             , numbersign    , U2299 ] };// ç 9 # ⊙
    key <AE10> { [ agrave        , 0             , at            , Greek_phi ] };// à 0 @ φ
    key <AE11> { [ parenright    , degree        , bracketright  , circle ] };// ) ° ] ○
    key <AE12> { [ equal         , plus          , braceright    , notequal ] };// = + } ≠
    
    // ============================================================
    // Second row - AZERTY + Emotions (NO DUPLICATES)
    // A = Angry  | Z = Zzz      | E = Explode   | R = Frustrated
    // T = Tired  | Y = Skeptical | U = Upset    | I = Ill
    // O = Ouch   | P = Panic    | ^ = Coin     | $ = Dollar
    // ============================================================

    key <AD01> { [ Arabic_alef   , Arabic_hamzaonalef, U1F620        , U1F621 ] };// ا أ 😠 😡
    key <AD02> { [ Arabic_zain   , Arabic_zah    , U1F634        , U1F4A4 ] };// ز ظ 😴 💤
    key <AD03> { [ Arabic_alefmaksura, Arabic_maddaonalef, U1F92F        , U1F4A5 ] };// ى آ 🤯 💥
    key <AD04> { [ Arabic_ra     , Arabic_ghain  , U1F624        , U1F629 ] };// ر غ 😤 😩
    key <AD05> { [ Arabic_teh    , Arabic_tah    , U1F971        , U1F62B ] };// ت ط 🥱 😫
    key <AD06> { [ Arabic_yeh    , Arabic_hamzaonyeh, U1F644        , U1F928 ] };// ي ئ 🙄 🤨
    key <AD07> { [ Arabic_ain    , Arabic_damma  , U1F61E        , U1F614 ] };// ع ُ 😞 😔
    key <AD08> { [ Arabic_hamzaunderalef, Arabic_kasra  , U1F637        , U1F912 ] };// إ ِ 😷 🤒
    key <AD09> { [ Arabic_tehmarbuta, Arabic_sukun  , U1F62D        , U1F622 ] };// ة ْ 😭 😢
    key <AD10> { [ Arabic_hamza  , Arabic_peh    , U1F631        , U1F630 ] };// ء پ 😱 😰
    key <AD11> { [ dead_circumflex, caron         , U1FA99        , U1F4B3 ] };// ﹒ ˇ 🪙 💳
    key <AD12> { [ dollar        , EuroSign      , U1F4B2        , U1F4B5 ] };// $ € 💲 💵

    // ============================================================
    // Third row - QSDFGHJKLM (NO DUPLICATES)
    // Q = Quiet   | S = Sad      | D = Depressed | F = Fear
    // G = Grumpy  | H = Happy    | J = Joy       | K = Kiss
    // L = Love    | M = Crazy    | ù = Music     | * = Star
    // ============================================================

    key <AC01> { [ Arabic_qaf    , Arabic_fathatan, U1F910        , U1F92B ] };// ق ً 🤐 🤫
    key <AC02> { [ Arabic_seen   , Arabic_sad    , U1F61F        , U1F625 ] };// س ص 😟 😥
    key <AC03> { [ Arabic_dal    , Arabic_dad    , U1F623        , U1F641 ] };// د ض 😣 🙁
    key <AC04> { [ Arabic_feh    , Arabic_fatha  , U1F627        , U1F626 ] };// ف َ 😧 😦
    key <AC05> { [ Arabic_jeem   , Arabic_ghain  , U1F612        , U1F92C ] };// ج غ 😒 🤬
    key <AC06> { [ Arabic_ha     , Arabic_hah    , U1F603        , U1F604 ] };// ه ح 😃 😄
    key <AC07> { [ Arabic_khah   , Arabic_dammatan, U1F602        , U1F606 ] };// خ ٌ 😂 😆
    key <AC08> { [ Arabic_kaf    , Arabic_kasratan, U1F618        , U1F970 ] };// ك ٍ 😘 🥰
    key <AC09> { [ Arabic_lam    , Arabic_tatweel, U1F60D        , U1F496 ] };// ل ـ 😍 💖
    key <AC10> { [ Arabic_meem   , Arabic_meem   , U1F92A        , U1F61C ] };// م م 🤪 😜
    key <AC11> { [ ugrave        , percent       , U1F3B5        , U1F3B6 ] };// ù % 🎵 🎶
    key <BKSL> { [ asterisk      , multiply      , U2B50         , U2728 ] };// * × ⭐ ✨

    // ============================================================
    // Fourth row - WXCVBN,;:! (NO DUPLICATES)
    // W = Wow     | X = eXcited  | C = Confused  | V = Vomit
    // B = Bored   | N = Shocked  | , = FLUSHED   | ; = Relieved
    // : = Smirk   | ! = Silly    | < > = Grimace
    // ============================================================

    key <LSGT> { [ less          , greater       , U1F62C        , U1F925 ] };// < > 😬 🤥
    key <AB01> { [ Arabic_waw    , Arabic_hamzaonwaw, U1F62E        , U1F609 ] };// و ؤ 😮 😉
    key <AB02> { [ Arabic_sheen  , Arabic_shadda , U1F929        , U1F60E ] };// ش ّ 🤩 😎
    key <AB03> { [ Arabic_theh   , Arabic_theh   , U1F615        , U1F635 ] };// ث ث 😕 😵
    key <AB04> { [ Arabic_thal   , Arabic_peh    , U1F92E        , U1F922 ] };// ذ پ 🤮 🤢
    key <AB05> { [ Arabic_beh    , Arabic_beh    , U1F611        , U1F610 ] };// ب ب 😑 😐
    key <AB06> { [ Arabic_noon   , N             , U1F632        , U1F92D ] };// ن N 😲 🤭
    key <AB07> { [ Arabic_comma  , Arabic_question_mark, U1F633        , U1F636 ] };// ، ؟ 😳 😶   <-- FLUSHED PRIORITY!
    key <AB08> { [ semicolon     , period        , U1F60C        , U1F60A ] };// ; . 😌 😊
    key <AB09> { [ colon         , slash         , U1F60F        , U1F914 ] };// : / 😏 🤔
    key <AB10> { [ exclam        , exclamdown    , U1F643        , U1F917 ] };// ! ¡ 🙃 🤗

    // ============================================================
    // Space & Modifiers
    // ============================================================

    key <SPCE> { [ space         , space         , U1F533        , U1F532 ] };//     🔳 🔲

    // ============================================================
    // Arrow keys
    // ============================================================

    key <UP> { [ Up            , Up            , U2B06         , U1F53C ] };//     ⬆ 🔼
    key <DOWN> { [ Down          , Down          , U2B07         , U1F53D ] };//     ⬇ 🔽
    key <LEFT> { [ Left          , Left          , U2B05         , U25C0 ] };//     ⬅ ◀
    key <RGHT> { [ Right         , Right         , U27A1         , U25B6 ] };//     ➡ ▶

    // ============================================================
    // Numpad
    // ============================================================

    key <KP7> { [ 7             , U2166         , U0667         , U277C ] };// 7 Ⅶ ٧ ❼
    key <KP8> { [ 8             , U2167         , U0668         , U277D ] };// 8 Ⅷ ٨ ❽
    key <KP9> { [ 9             , U2168         , U06F9         , U277E ] };// 9 Ⅸ ۹ ❾
    key <KP4> { [ 4             , U2163         , U0664         , U2779 ] };// 4 Ⅳ ٤ ❹
    key <KP5> { [ 5             , U2164         , U0665         , U277A ] };// 5 Ⅴ ٥ ❺
    key <KP6> { [ 6             , U2165         , U0666         , U277B ] };// 6 Ⅵ ٦ ❻
    key <KP1> { [ 1             , U2160         , U0661         , U2776 ] };// 1 Ⅰ ١ ❶
    key <KP2> { [ 2             , U2161         , U0662         , U2777 ] };// 2 Ⅱ ٢ ❷
    key <KP3> { [ 3             , U2162         , U0663         , U2778 ] };// 3 Ⅲ ٣ ❸
    key <KP0> { [ 0             , U2169         , U0660         , U277F ] };// 0 Ⅹ ٠ ❿

